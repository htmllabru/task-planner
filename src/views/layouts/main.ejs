<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>📝 <%= title %> — Task Planner</title>
  <link rel="stylesheet" href="/css/app.css" />
</head>
<body class="min-h-screen bg-slate-50 text-slate-900">
  <nav class="border-b border-slate-200 bg-white">
    <div class="mx-auto flex max-w-4xl items-center justify-between px-4 py-3">
      <a href="/" class="text-lg font-semibold text-indigo-600">Task Planner</a>
      <div class="flex gap-4 text-sm">
        <% if (typeof email !== 'undefined' && email) { %>
          <a href="/cabinet" class="hover:text-indigo-600">Кабинет</a>
          <a href="/tasks" class="hover:text-indigo-600">Задачи</a>
          <form action="/logout" method="post" class="inline">
            <button type="submit" class="text-red-600 hover:underline">Выход</button>
          </form>
        <% } else { %>
          <a href="/login" class="hover:text-indigo-600">Вход</a>
          <a href="/register" class="hover:text-indigo-600">Регистрация</a>
        <% } %>
      </div>
    </div>
  </nav>
  <main class="mx-auto max-w-4xl px-4 py-8">
    <%- body %>
  </main>
</body>
</html>
