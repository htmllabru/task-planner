<h1 class="mb-2 text-2xl font-bold">Личный кабинет</h1>
<p class="mb-6 text-slate-600">Вы вошли как <strong><%= email %></strong></p>

<% if (success === 'revoked') { %>
  <p class="mb-4 rounded-lg bg-green-50 p-3 text-sm text-green-800">API-ключ отозван</p>
<% } %>

<% if (newKey) { %>
  <div class="mb-6 rounded-lg border-2 border-amber-300 bg-amber-50 p-4">
    <p class="mb-2 font-semibold text-amber-900">Новый API-ключ (сохраните сейчас — больше не покажем):</p>
    <code class="block break-all rounded bg-white p-2 text-sm"><%= newKey %></code>
    <p class="mt-2 text-xs text-amber-800">Используйте заголовок <code>X-API-Key</code> для серверных запросов к /api</p>
  </div>
<% } %>

<section class="mb-8 rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
  <h2 class="mb-4 text-lg font-semibold">API-ключи</h2>
  <form method="post" action="/cabinet/api-keys" class="mb-6 flex gap-2">
    <input type="text" name="label" placeholder="Название (например: CI bot)" class="flex-1 rounded-lg border border-slate-300 px-3 py-2" />
    <button type="submit" class="rounded-lg bg-indigo-600 px-4 py-2 text-white hover:bg-indigo-700">Создать ключ</button>
  </form>
  <% if (keys.length === 0) { %>
    <p class="text-sm text-slate-500">Ключей пока нет</p>
  <% } else { %>
    <ul class="space-y-2">
      <% keys.forEach(function(k) { %>
        <li class="flex items-center justify-between rounded-lg border border-slate-100 px-3 py-2 text-sm">
          <span>
            <strong><%= k.label %></strong>
            <span class="ml-2 font-mono text-slate-500"><%= k.key_prefix %>…</span>
            <% if (k.revoked_at) { %>
              <span class="ml-2 rounded bg-red-100 px-2 py-0.5 text-xs text-red-700">отозван</span>
            <% } %>
          </span>
          <% if (!k.revoked_at) { %>
            <form method="post" action="/cabinet/api-keys/<%= k.id %>/revoke">
              <button type="submit" class="text-red-600 hover:underline">Отозвать</button>
            </form>
          <% } %>
        </li>
      <% }); %>
    </ul>
  <% } %>
</section>

<p class="text-sm"><a href="/tasks" class="text-indigo-600 hover:underline">Перейти к задачам →</a></p>
