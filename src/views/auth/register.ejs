<h1 class="mb-6 text-2xl font-bold">Регистрация</h1>
<% if (error) { %>
  <p class="mb-4 rounded-lg bg-red-50 p-3 text-sm text-red-700"><%= error %></p>
<% } %>
<form method="post" action="/register" class="max-w-md space-y-4 rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
  <div>
    <label class="mb-1 block text-sm font-medium">Email</label>
    <input type="email" name="email" required class="w-full rounded-lg border border-slate-300 px-3 py-2" />
  </div>
  <div>
    <label class="mb-1 block text-sm font-medium">Пароль (мин. 6)</label>
    <input type="password" name="password" required minlength="6" class="w-full rounded-lg border border-slate-300 px-3 py-2" />
  </div>
  <button type="submit" class="w-full rounded-lg bg-indigo-600 px-4 py-2 text-white hover:bg-indigo-700">Зарегистрироваться</button>
</form>
<p class="mt-4 text-sm text-slate-600">Уже есть аккаунт? <a href="/login" class="text-indigo-600 hover:underline">Войти</a></p>
